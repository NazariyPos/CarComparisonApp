{
  "metadata": [
    {
      "src": [
        {
          "files": [
            "CarComparisonApi/CarComparisonApi.csproj"
          ]
        }
      ],
      "dest": "api",
      "properties": {
        "RunAnalyzers": "false",
        "RunAnalyzersDuringBuild": "false",
        "RunAnalyzersDuringLiveAnalysis": "false"
      },
      "suppress": [
        "FailedToLoadAnalyzer"
      ]
    }
  ],
  "build": {
    "content": [
      {
        "src": "docs",
        "files": [
          "**.md",
          "**/toc.yml"
        ]
      },
      {
        "files": [
          "api/**.yml",
          "api/**.md",
          "api/toc.yml"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "docs/images/**"
        ]
      }
    ],
    "dest": "_site",
    "globalMetadata": {
      "_appTitle": "CarComparisonApi Documentation"
    }
  }
}
